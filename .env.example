APP_ENV=development
DEBUG=true

# MySQL（必须在 .env 中填写真实连接串，示例不包含真实账号密码/地址）
DATABASE_URL=mysql+aiomysql://root:<your_mysql_password>@<your_mysql_host>:3306/release_center?charset=utf8mb4

# 供 docker-compose 启动本地 MySQL 使用（同样只放示例占位符）
MYSQL_ROOT_PASSWORD=<your_mysql_password>
MYSQL_DATABASE=release_center
MYSQL_CHARSET=utf8mb4

# 阿里云百炼（OpenAI 兼容接口）
OPENAI_API_KEY=sk-...
OPENAI_MODEL=qwen-plus
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

GITLAB_URL=https://gitlab.example.com
GITLAB_TOKEN=glpat-...

ZADIG_URL=https://zadig.example.com
ZADIG_TOKEN=...

LARK_APP_ID=cli_...
LARK_APP_SECRET=...
LARK_VERIFICATION_TOKEN=...
LARK_ENCRYPT_KEY=...
